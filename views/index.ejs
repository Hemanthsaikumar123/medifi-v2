<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Medify — Medicine Finder</title>
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>

<div class="layout">

  <!-- ── Sidebar ──────────────────────────────────────────── -->
  <aside class="sidebar">

    <div class="sidebar-brand">
      <div class="sidebar-brand-icon">💊</div>
      <h2>Medify</h2>
    </div>

    <% if (user) { %>
      <div class="sidebar-user">
        <div class="sidebar-user-label">Signed in as</div>
        <div class="sidebar-user-name"><%= user.username %></div>
      </div>
    <% } %>

    <nav class="sidebar-nav">
      <ul>
        <li><a href="/?section=home"><span class="nav-icon">🏠</span> Home</a></li>
        <li><a href="/?section=manual"><span class="nav-icon">🔍</span> Manual Search</a></li>
        <li><a href="/?section=bot"><span class="nav-icon">🤖</span> Ask Medify</a></li>
        <li><a href="/?section=flow"><span class="nav-icon">🧭</span> Symptom Flow</a></li>
        <% if (user) { %>
          <li><a href="/history"><span class="nav-icon">📜</span> My History</a></li>
        <% } %>
      </ul>
    </nav>

    <% if (!user) { %>
      <div class="sidebar-auth-links">
        <a href="/login"><span class="nav-icon">🔐</span> Login</a>
        <a href="/signup"><span class="nav-icon">✏️</span> Sign up</a>
      </div>
    <% } else { %>
      <div class="sidebar-auth-links">
        <a href="/logout"><span class="nav-icon">🚪</span> Logout</a>
      </div>
    <% } %>

    <div class="sidebar-footer">
      <button id="toggleMode">🌙 &nbsp;Dark mode</button>
    </div>

  </aside>

  <!-- ── Main Content ──────────────────────────────────────── -->
  <main class="main-content">

    <% if (section === 'home') { %>
      <div class="home-dashboard">
        <div class="page-header">
          <h2>Welcome to Medify 💊</h2>
          <p>Instant drug info, symptom checks, and AI-powered medical guidance.</p>
        </div>
        <div class="info-cards">
          <div class="card">
            <div class="card-label">Diseases covered</div>
            <div class="card-value">25+</div>
            <div class="card-desc">Across 9 body areas</div>
          </div>
          <div class="card">
            <div class="card-label">AI assistant</div>
            <div class="card-value">Smart bot</div>
            <div class="card-desc">Describe your symptoms naturally</div>
          </div>
          <div class="card">
            <div class="card-label">Data source</div>
            <div class="card-value">OpenFDA</div>
            <div class="card-desc">Live official drug database</div>
          </div>
        </div>
        <form action="/manual" method="POST" class="manual-form">
          <input type="text" name="query" placeholder="Quick search — enter a disease or drug name…" />
          <button type="submit">Search</button>
        </form>
      </div>

    <% } else if (section === 'manual') { %>
      <section class="manual-search">
        <div class="page-header">
          <h2>Drug Search</h2>
          <p>Look up any drug or disease via the OpenFDA database.</p>
        </div>
        <form action="/manual" method="POST" class="manual-form">
          <input type="text" name="query" placeholder="Enter disease or brand name…" required />
          <button type="submit">Search</button>
        </form>
        <% if (manualResult) { %>
          <div class="result-box">

            <div class="manual-result-head">
              <span class="manual-type-badge manual-type-<%= manualResult.type === 'disease' ? 'disease' : 'medicine' %>">
                <%= manualResult.type === 'disease' ? 'Disease / Symptom' : 'Medicine' %>
              </span>
              <h3 class="manual-result-title"><%= manualResult.name %></h3>
            </div>

            <div class="manual-result-rows">
              <div class="manual-row">
                <span class="manual-label">Summary</span>
                <span class="manual-value"><%= manualResult.summary %></span>
              </div>

              <% if (manualResult.dosage && manualResult.dosage !== 'N/A') { %>
                <div class="manual-row">
                  <span class="manual-label">Dosage</span>
                  <span class="manual-value"><%= manualResult.dosage %></span>
                </div>
              <% } %>

              <% if (manualResult.warning && manualResult.warning !== 'N/A') { %>
                <div class="manual-row manual-warning-row">
                  <span class="manual-label">Warning</span>
                  <span class="manual-value"><%= manualResult.warning %></span>
                </div>
              <% } %>
            </div>

            <% if (manualResult.medicines && manualResult.medicines.length > 0) { %>
              <div class="manual-medicines-block">
                <span class="manual-label">Common Medicines</span>
                <div class="manual-pills">
                  <% manualResult.medicines.forEach(function(item) { %>
                    <span class="manual-pill"><%= item %></span>
                  <% }); %>
                </div>
              </div>
            <% } %>

            <div class="manual-result-footer">
              <a href="https://medlineplus.gov/search/?query=<%= encodeURIComponent(manualResult.name) %>" target="_blank">
                🔗 Full info on MedlinePlus
              </a>
            </div>
          </div>

        <% } else if (manualError) { %>
          <div class="result-box" style="text-align:center;padding:28px;">
            <div style="font-size:28px;margin-bottom:10px;">🔍</div>
            <p style="font-weight:600;color:var(--text-primary);margin-bottom:6px;">No results found</p>
            <p style="font-size:13px;color:var(--text-secondary);"><%= manualError %></p>
          </div>
        <% } %>

      </section>

    <% } else if (section === 'flow') { %>
      <section class="chatbot-container">
        <div class="page-header">
          <h2>Symptom Flow</h2>
          <p>Follow the guided flow to identify your condition and get advice.</p>
        </div>

        <% if (!flowStep || flowStep === 1) { %>
          <form action="/flow-step" method="POST">
            <label style="font-size:14px;font-weight:500;color:var(--text-secondary);display:block;margin-bottom:12px;">Where are your symptoms?</label>
            <div class="flow-options">
              <button type="submit" name="category" value="head">🧠 Head</button>
              <button type="submit" name="category" value="chest">❤️ Chest</button>
              <button type="submit" name="category" value="stomach">🍽️ Stomach</button>
              <button type="submit" name="category" value="joints">🦵 Joints</button>
              <button type="submit" name="category" value="skin">🧴 Skin</button>
              <button type="submit" name="category" value="eye">👁️ Eye</button>
              <button type="submit" name="category" value="throat">🗣️ Throat</button>
              <button type="submit" name="category" value="back">🔙 Back</button>
              <button type="submit" name="category" value="general">🧍 General</button>
            </div>
          </form>

        <% } else if (flowStep === 2) { %>
          <form action="/flow-diagnose" method="POST">
            <input type="hidden" name="category" value="<%= category %>">
            <label style="font-size:14px;font-weight:500;color:var(--text-secondary);display:block;margin-bottom:12px;">Select your specific symptom:</label>
            <div class="flow-options">
              <% options.forEach(option => { %>
                <button type="submit" name="symptom" value="<%= option %>"><%= option %></button>
              <% }) %>
            </div>
          </form>

        <% } else if (flowStep === 3) { %>
          <div class='result-box'>
            <h3><%= condition %></h3>
            <p><strong>Advice:</strong> <%= advice %></p>
            <a href='https://medlineplus.gov/search/?query=<%= encodeURIComponent(condition) %>' target='_blank'>
              Learn more on MedlinePlus
            </a>
          </div>

        <% } %>
      </section>

    <% } else { %>k
      <section class="chatbot-container">
        <div class="page-header">
          <h2>Ask Medify</h2>
          <p>Describe your symptoms and get AI-powered guidance.</p>
        </div>
        <form method="POST" action="/chat" class="chat-form">
          <input type="text" name="message" placeholder="Describe your symptoms…" required />
          <button type="submit">Ask</button>
        </form>
        <% if (reply && typeof reply === 'object') { %>
          <div class="result-box">
            <% if (reply.query) { %>
              <p style="font-size:13px;color:var(--text-secondary);margin-bottom:10px;">
                You asked: "<%= reply.query %>"
              </p>
            <% } %>

            <h3 style="margin-bottom:12px;"><%= reply.title %></h3>

            <p style="margin-bottom:10px;">
              <strong>Summary:</strong> <%= reply.summary %>
            </p>

            <a href="https://medlineplus.gov/search/?query=<%= encodeURIComponent(reply.title) %>"
               target="_blank"
               style="display:inline-flex;align-items:center;gap:5px;margin-top:8px;color:var(--brand);font-size:13px;font-weight:500;text-decoration:none;">
              🔗 Learn more about <%= reply.title %> on MedlinePlus
            </a>

          </div>
        <% } %>
      </section>
    <% } %>

  </main>
</div>

<footer>
  <p>&copy; <%= new Date().getFullYear() %> Medify. Not a substitute for professional medical advice.</p>
</footer>

<script src="/js/script.js"></script>
</body>
</html>
