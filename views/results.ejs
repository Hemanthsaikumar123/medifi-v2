<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Results for "<%= query %>" | MediFi</title>
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>
  <header>
    <h1>MediFi</h1>
    <p>Search Results for "<%= query %>"</p>
    <a href="/" style="color:white;">← Back to Search</a>
  </header>

  <main class="results">
    <% if (error) { %>
      <h2><%= error %></h2>
    <% } else { %>
      <div class="card">
        <h2><%= medicine.openfda.brand_name ? medicine.openfda.brand_name[0] : 'Unknown' %></h2>
        <p><strong>Generic Name:</strong> <%= medicine.openfda.generic_name ? medicine.openfda.generic_name[0] : 'N/A' %></p>
        <p><strong>Purpose:</strong> <%= medicine.purpose ? medicine.purpose[0] : 'N/A' %></p>
        <p><strong>Indications:</strong> <%= medicine.indications_and_usage ? medicine.indications_and_usage[0] : 'N/A' %></p>
        <p><strong>Warnings:</strong> <%= medicine.warnings ? medicine.warnings[0] : 'N/A' %></p>
        <p><strong>Dosage:</strong> <%= medicine.dosage_and_administration ? medicine.dosage_and_administration[0] : 'N/A' %></p>
      </div>
    <% } %>
  </main>

  <footer>
    <p>&copy; <%= new Date().getFullYear() %> MediFi. All rights reserved.</p>
  </footer>
</body>
</html>
