<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Suggestions for "<%= condition %>" — Medify</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>

  <header>
    <div>
      <h1>Medify</h1>
      <p>Medicine suggestions for "<%= condition %>"</p>
    </div>
    <a href="/">← Back to Home</a>
  </header>

  <main class="results">

    <% if (results && results.length > 0) { %>
      <% results.forEach(med => { %>
        <div class="card">
          <h2><%= med.openfda.brand_name ? med.openfda.brand_name[0] : 'Unknown Brand' %></h2>
          <p>
            <strong>Generic</strong>
            <%= med.openfda.generic_name ? med.openfda.generic_name[0] : 'N/A' %>
          </p>
          <p>
            <strong>Indications</strong>
            <%= med.indications_and_usage ? med.indications_and_usage[0] : 'N/A' %>
          </p>
        </div>
      <% }) %>
    <% } else { %>
      <div class="card">
        <p style="color:var(--text-secondary)"><%= error || 'No results found.' %></p>
      </div>
    <% } %>

  </main>

  <footer style="position:static;border-top:1px solid var(--border);padding:14px 24px;color:var(--text-tertiary);font-size:12px;text-align:center;">
    &copy; <%= new Date().getFullYear() %> Medify. Not a substitute for professional medical advice.
  </footer>

  <script src="/js/script.js"></script>
</body>
</html>
